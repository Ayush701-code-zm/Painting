{
  "name": "backend",
  "version": "1.0.0",
  "description": "Glamsfyt backend API — Node.js / Express / MongoDB",
  "main": "src/index.js",
  "engines": {
    "node": ">=12.0.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --forceExit --detectOpenHandles --testPathPattern=tests/",
    "test:unit": "jest --forceExit --detectOpenHandles --testPathPattern=tests/unit/",
    "test:integration": "jest --forceExit --detectOpenHandles --testPathPattern=tests/integration/",
    "test:coverage": "jest --forceExit --detectOpenHandles --coverage --testPathPattern=tests/",
    "lint": "eslint src/ tests/",
    "audit": "npm audit",
    "audit:check": "npm audit --audit-level=moderate",
    "audit:fix": "npm audit fix",
    "security:check": "npm audit && npm outdated"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "setupFiles": [
      "dotenv/config"
    ]
  },
  "keywords": [
    "nodejs",
    "express",
    "mongodb",
    "rest-api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.758.0",
    "@aws-sdk/lib-storage": "^3.758.0",
    "@aws-sdk/s3-request-presigner": "^3.758.0",
    "@hapi/joi": "^17.1.0",
    "amqplib": "^0.10.7",
    "bcryptjs": "^3.0.2",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.3",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.0",
    "formidable": "^3.5.2",
    "helmet": "^8.0.0",
    "http-status": "^1.7.4",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "mongoose": "^8.15.1",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.10.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "socket.io": "^4.8.1",
    "uuid": "^11.1.0",
    "validator": "^13.15.26",
    "winston": "^3.17.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.0"
  }
}
